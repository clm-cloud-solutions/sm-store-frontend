# Store Frontend (Next.js) — Environment Variables
# Depends on: Store Backend API

# URL of the Store Backend API (required, used client-side and server-side)
# e.g. https://gitlab-sm-store-backend.vercel.app
NEXT_PUBLIC_API_URL=

# --- Vercel CI/CD (set in GitLab CI/CD variables) ---
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
